# Fichier de configuration des variables d'environnement
# IMPORTANT : Copiez ce fichier en '.env' et remplissez les valeurs.
# Ne committez JAMAIS le fichier '.env' sur Git (il est dans .gitignore).

# =========================================
# BASE DE DONNÉES POSTGRESQL
# =========================================
POSTGRES_DB=gmpp_db
POSTGRES_USER=gmpp_user
POSTGRES_PASSWORD=ChangeThisPasswordInProduction!

# =========================================
# SÉCURITÉ JWT (OBLIGATOIRE)
# Bug 2 fix: ce secret doit être défini avant de lancer l'application.
# Générer un secret sécurisé avec la commande :
#   openssl rand -base64 64
# =========================================
JWT_SECRET=REMPLACEZ_PAR_UN_SECRET_FORT_DE_64_CARACTERES_MINIMUM_GENERE_ALEATOIREMENT

# =========================================
# PROFIL SPRING BOOT
# 'dev' active le DataInitializer (données de test)
# 'prod' pour la production (pas de données de test)
# =========================================
SPRING_PROFILES_ACTIVE=dev

# =========================================
# CONFIGURATION EMAIL (OPTIONNEL — Feat 3)
# Activer pour recevoir les alertes J-7/J-3/J-1 par email.
# =========================================
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=votre.email@gmail.com
# MAIL_PASSWORD=votre-app-password-gmail
# GMPP_ALERT_EMAIL_ENABLED=true
